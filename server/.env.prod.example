# ═══════════════════════════════════════════════
#  生产环境变量（服务器上 cp .env.prod.example .env.prod，然后填写）
#  用法：docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# ═══════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=starpath
POSTGRES_PASSWORD=换一个强密码_至少16位
POSTGRES_DB=starpath

# ── JWT ──────────────────────────────────────
JWT_SECRET=换一个强随机字符串_至少32位

# ── AI 大模型（二选一填写）───────────────────

# 方案 A：Kimi（现有配置）
LLM_PROVIDER=kimi
KIMI_CODE_API_KEY=sk-kimi-你的key
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1

# 方案 B：豆包（火山方舟）
# LLM_PROVIDER=doubao
# ARK_API_KEY=你的方舟APIKey
# LLM_MODEL=doubao-pro-32k
