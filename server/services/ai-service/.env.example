# ═══════════════════════════════════════════════
#  Starpath AI Service 环境变量
#  cp .env.example .env  然后填入真实密钥
# ═══════════════════════════════════════════════

# ── 大模型选择（LLM_PROVIDER = doubao | kimi）──────────────────────────────
LLM_PROVIDER=doubao

# ── 豆包（火山方舟）──────────────────────────────────────────────────────────
# 控制台：https://console.volcengine.com/ark  → API Keys
ARK_API_KEY=your-ark-api-key-here
# 推荐模型：doubao-pro-32k / doubao-lite-32k / doubao-pro-128k
LLM_MODEL=doubao-pro-32k

# ── Kimi Code（备用）────────────────────────────────────────────────────────
# 控制台：https://www.kimi.com/code → 会员页面 → API Keys（格式 sk-kimi-...）
# 切换时把 LLM_PROVIDER 改为 kimi
KIMI_CODE_API_KEY=sk-kimi-your-key-here
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
