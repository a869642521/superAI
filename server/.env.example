# ═══════════════════════════════════════════════
#  Starpath NestJS 后端环境变量
#  cp .env.example .env  然后按需填写
# ═══════════════════════════════════════════════

# 数据库（docker-compose 映射 5433→5432）
DATABASE_URL="postgresql://starpath:starpath_dev_2024@localhost:5433/starpath?schema=public"

# Redis（docker-compose 映射 6380→6379）
REDIS_URL="redis://localhost:6380"

# JWT
JWT_SECRET=dev-secret-change-in-prod

# 服务端口
PORT=3000

# AI 服务地址（fastapi，与 Flutter 端 constants.dart 保持一致）
AI_SERVICE_URL=http://localhost:8000
